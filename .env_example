# VK Bot Configuration
VK_TOKEN=                         # VK API токен бота (получить в настройках сообщества -> Работа с API)
USER_ID=                          # ID пользователя, чтобы бот слушал только владельца (узнать: vk.com/foaf.php?uid=YOUR_USER_ID)
GROUP_ID=                         # ID сообщества (группы) VK, в котором живет бот (со знаком минус не указывать)
CHAT_PEER_ID=                     # ID чата (беседы) для ответов (2000000000 + id беседы)
API_VERSION=5.199                 # Версия VK API (актуальную версию см. в документации VK)

# LM Studio Configuration
LM_STUDIO_URL=                    # URL LM Studio API (по умолчанию http://localhost:1234/v1)
LM_STUDIO_API_KEY=                # API ключ LM Studio (взять в Settings -> Developer)
LM_MODEL_KEY=                     # Ключ модели для загрузки (например, qwen3.5-9b)
LM_CONTEXT_LENGTH=65536           # Размер контекста модели (токенов)
LM_PARALLEL=4                     # Количество параллельных сессий модели
LM_GPU_OFFLOAD=1                  # 1 = полная загрузка модели на GPU, 0 = CPU

# OpenRouter Configuration (опционально, для внешних моделей)
OPENROUTER_URL=https://openrouter.ai/api/v1  # URL API OpenRouter
OPENROUTER_KEY=                   # API ключ OpenRouter (получить на openrouter.ai)

# Search Service
SEARCH_URL=                       # URL внешнего поискового сервиса (например, https://google/search)

# System
PROJECTS_ROOT=./projects          # Корневая папка для проектов/данных бота
